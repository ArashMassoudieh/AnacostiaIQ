    {
      "id": "moisture_sensor",
      "type": "moisture",
      "unit": "%",
      "name": "Soil Moisture",
      "params": {
        "chip": "/dev/gpiochip0",
        "dataPins": [5, 6, 13, 19, 26, 16, 20, 21],
        "wrPin": 23,
        "rdPin": 24,
        "intrPin": 25,
        "adcDry": 105,
        "adcWet": 32
